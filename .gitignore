# ── CMake ────────────────────────────────────────────────────────────────────
build/
_build/
local_build/
out/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
Makefile
*.make

# CTest output
Testing/

# ── Compiled objects and binaries ────────────────────────────────────────────
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# Linux binaries without extension (from direct hipcc invocations)
# Convention: always compile to build/ or local_build/ — never to project root.
# If you do compile manually, add the binary name here or use local_build/.

# ── HIP / ROCm specific ──────────────────────────────────────────────────────
*.hsaco          # HIP shader compiled object
*.co             # code object
*.gcno           # gcov notes (HIP coverage)
*.gcda           # gcov data
*.hip.cpp        # HIPIFY output

# LLVM intermediate artifacts (from hipcc --save-temps or --emit-llvm)
*.ll             # LLVM IR text
*.bc             # LLVM bitcode
*.amdgcn.bc      # AMD GCN bitcode
*.s              # assembly output
*.d              # compiler dependency files

hipify-output/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
venv/
.venv/
env/
dist/
*.whl

# Jupyter (AMD Developer Cloud uses JupyterLab)
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Profiler outputs ─────────────────────────────────────────────────────────
# rocprofv3 generates JSON, CSV, SQLite — exclude by default.
# If you want to commit a specific result, use: git add -f path/to/result.json
*.csv
*.json
*.db
*.sqlite
rocprof_output/
hsa_trace/
*.perfetto

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.VC.db
*.VC.VC.opendb

# clangd LSP cache
.cache/
compile_commands.json

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# Linux core dumps
core
core.*

# ── Logs and temp ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
tmp/
temp/

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
*.pem
*.key
*.secret
